# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must match GOOGLE_REDIRECT_URL exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ── Resend API Key ─────────────────────────────────────────────────────────────
RESEND_API_KEY= 

ENV=local # can be local or dev
LOCAL_API_URl=
DEV_API_URL=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to LOCAL_API_URL when unset.
# Use * to allow all origins (disables credentials).
# For production, include your production frontend URL(s)
# Example: ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.com
ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_ORIGINS=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret API key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# URL to redirect to after a successful Stripe Checkout session
STRIPE_SUCCESS_URL=
# URL to redirect to when the user cancels Stripe Checkout
STRIPE_CANCEL_URL=
