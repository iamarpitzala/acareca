{
  "info": {
    "name": "Acareca API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.id) {",
                  "    pm.collectionVariables.set('userId', body.data.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"phone\": \"+11234567890\",\n  \"is_superadmin\": false\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"data\": {\n    \"id\": \"uuid\",\n    \"email\": \"john.doe@example.com\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone\": \"+11234567890\",\n    \"is_superadmin\": false,\n    \"created_at\": \"2026-03-06T00:00:00Z\",\n    \"updated_at\": \"2026-03-06T00:00:00Z\"\n  }\n}"
            },
            {
              "name": "409 Email Taken",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"error\": \"email already taken\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.access_token) {",
                  "    pm.collectionVariables.set('accessToken', body.data.access_token);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\",\n  \"is_superadmin\": false\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"is_superadmin\": false\n  }\n}"
            },
            {
              "name": "401 Invalid Credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"error\": \"invalid password\"\n}"
            }
          ]
        },
        {
          "name": "Google Auth URL",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "google"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"url\": \"https://accounts.google.com/o/oauth2/auth?...\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Google Callback",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google/callback?code=GOOGLE_AUTH_CODE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "google", "callback"],
              "query": [
                {
                  "key": "code",
                  "value": "GOOGLE_AUTH_CODE",
                  "description": "Authorization code returned by Google"
                }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"is_superadmin\": false\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Engine",
      "item": [
        {
          "name": "Calculate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/calculate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "calculate"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"income\": [\n    {\n      \"name\": \"Salary\",\n      \"value\": 5000,\n      \"tax\": \"inclusive\",\n      \"tax_value\": null\n    },\n    {\n      \"name\": \"Freelance\",\n      \"value\": 1000,\n      \"tax\": \"exclusive\",\n      \"tax_value\": 100\n    }\n  ],\n  \"expense\": [\n    {\n      \"name\": \"Rent\",\n      \"value\": 1200,\n      \"tax\": \"exclusive\",\n      \"tax_value\": null\n    },\n    {\n      \"name\": \"Groceries\",\n      \"value\": 300,\n      \"tax\": \"manual\",\n      \"tax_value\": 27.5\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Calculate net income/expense totals with tax treatment.\n\n**Tax Treatment options:**\n- `inclusive` — tax is already included in the value\n- `exclusive` — tax will be added on top of the value\n- `manual` — supply a fixed tax amount via `tax_value`"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"income\": [5000, 1100],\n    \"expense\": [1200, 327.5],\n    \"result\": 4572.5\n  }\n}"
            },
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"validation error\"\n}"
            }
          ]
        },
        {
          "name": "Calculate - Income Only",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/calculate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "calculate"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"income\": [\n    {\n      \"name\": \"Product Sales\",\n      \"value\": 10000,\n      \"tax\": \"exclusive\",\n      \"tax_value\": 1000\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Calculate - Expense Only",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/calculate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "calculate"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expense\": [\n    {\n      \"name\": \"Office Supplies\",\n      \"value\": 450,\n      \"tax\": \"inclusive\",\n      \"tax_value\": null\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    }
  ]
}
